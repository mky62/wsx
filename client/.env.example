# Example client environment variables for Vite
# Copy this file to `.env` and fill with real values before running locally or in CI.

VITE_API_URL=https://api.example.com
VITE_WS_URL=wss://ws.example.com

# VITE_ prefixed keys are the only ones exposed to client-side code via import.meta.env
# Keep secrets on the server — do NOT store private keys or secrets in client env files.
